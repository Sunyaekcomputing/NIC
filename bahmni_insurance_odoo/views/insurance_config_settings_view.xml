<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="insurance_config_settings_form_view" model="ir.ui.view">
        <field name="name">EMR Settings</field>
        <field name="model">insurance.config.settings</field>
        <field name="arch" type="xml">
            <form string="EMR Settings" create="false" edit="true" delete="false">
                <header>
                    <button string="Apply" type="object" name="execute" class="oe_highlight"/>
                    or
                    <button string="Cancel" type="object" name="cancel" class="oe_link"/>
                </header>
                <sheet>
                    <div class="alert alert-success alert-dismissible" invisible="not context.get('show_message', False)">
                        Connection Succesfull!!!
                    </div>
                    <separator string="Insurance Connect Configuration" style="font-size: 16px;"/>
                    <group string="Bahmni Credentials" style="font-size: 14px;">
                        <group>
                            <field name="username" string="Username"/>
                            <field name="password" string="Password" password="True"/>
                            <field name="base_url"/>
                        </group>
                    </group>
                    <div>
                        <button name="action_test_connection" type="object" class="oe_highlight" string="Test Connection" />
                    </div>
                    <separator string="OpenMRS Connect Configuration" style="font-size: 16px"/>
                    <group string="OpenMRS Credentials" style="font-size: 14px;">
                        <group>
                            <field name="openmrs_username"/>
                            <field name="openmrs_password" password="True"/>
                            <field name="openmrs_base_url"/>
                        </group>
                    </group>
                    <group>
                        <group string="Claim Code Setup" style="font-size: 14px;">
                            <label for="manually_setup_claim_code" string="Setup Claim Code Manually"/>
                            <field name="manually_setup_claim_code"/>
                            <group attrs="{'invisible': [('manually_setup_claim_code', '=', False)]}">
                                <field name="claim_code_start_range" string="Start Range"/>
                                <field name="claim_code_end_range" string="End Range"/>
                                <field name="claim_code_next_val" string="Next Value"/>
                            </group>
                        </group>
                        <group string="IPD Number Setup" style="font-size: 14px;">
                            <label for="manually_setup_ipd_number" string="Setup IPD Number Manually"/>
                            <field name="manually_setup_ipd_number"/>
                            <group attrs="{'invisible': [('manually_setup_ipd_number', '=', False)]}">
                                <field name="ipd_number_start_range" string="Start Range"/>
                                <field name="ipd_number_end_range" string="End Range"/>
                                <field name="ipd_number_next_val" string="Next Value"/>
                            </group>
                        </group>
                    </group>
                    <group string="Journal Setup" style="font-size: 14px;">
                        <field name="insurance_journal"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_insurance_config_settings" model="ir.actions.act_window">
        <field name="name">EMR Settings</field>
        <field name="res_model">insurance.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="insurance_config_settings_form_view"></field>
    </record>
    <menuitem id="menu_emr_settings" name="EMR Settings" sequence="5" parent="menu_emr_configuration" action="action_insurance_config_settings"/>
</odoo>