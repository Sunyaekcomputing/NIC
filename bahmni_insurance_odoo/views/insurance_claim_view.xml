<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="insurance_claim_form_view" model="ir.ui.view">
        <field name="name">Insurance Claim Form View</field>
        <field name="model">insurance.claim</field>
        <field name="arch" type="xml">
            <form string="Claims">
                <header>
                    <button name="action_confirm" string="Confirm Claim" type="object" class="btn-primary" 
                        attrs="{'invisible': [('state', 'in', ['confirmed', 'entered', 'submitted', 'checked', 'valuated'])]}"/>
                    <button name="action_claim_submit" string="Submit Claim" type="object" class="btn-primary" 
                        attrs="{'invisible': [('state', 'in', ['draft', 'entered', 'submitted', 'checked', 'valuated', 'processed', 'rejected'])]}"/>
                    <button name="action_refund" string="Refund" type="object" class="btn-primary"
                        attrs="{'invisible': [('state', 'not in', ['entered', 'checked'])]}" 
                        confirm="This action will refund products/services in IMIS and cannot be undone. Do you want to continue?"/>
                    <field name="state" statusbar_visible="draft, confirmed, submitted" widget="statusbar"/>
                </header>
                <sheet>
                    <group> 
                        <group>
                            <field name="claim_code"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="nhis_number" readonly="1"/>
                            <field name="nmc_number"/>
                            <field name="care_setting" readonly="1"/>
                            <field name="claim_uuid"/>
                            <field name="rejection_reason" readonly="1"/>
                        </group>
                        <group>
                            <field name="claimed_date" readonly="1"/>
                            <field name="claim_manager_id" readonly="1"/>
                            <field name="external_visit_uuid"/>
                            <field name="generated_claim_code"/>
                            <field name="claim_explanation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Claim Items">
                            <field name="insurance_claim_line">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="imis_product_code"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="total_price"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right" colspan="2">
                                <field name="claimed_amount_total"/>
                            </group>
                        </page>
                        <page string="Sale Orders">
                            <field name="sale_orders"/>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="datas"/>
                                </tree>
                            </field>
                            <button name="generate_opd_one_pager" string="Generate OPD One Pager" type="object" class="btn-primary"/>
                        </page>
                        <page string="Diagnosis">
                            <field name="icd_code">
                                <tree editable="bottom">
                                    <field name="icd_code"/>
                                    <field name="diagnosis"/>
                                </tree>
                            </field>
                            <button name="action_retrieve_diagnosis" string="Retrieve Diagnosis" type="object" class="btn-primary"/>
                        </page>
                        <page string="Claim History">
                            <field name="insurance_claim_history">
                                <tree editable="bottom">
                                    <field name="claim_code"/>
                                    <field name="partner_id"/>
                                    <field name="claim_manager_id"/>
                                    <field name="claim_status"/>
                                    <field name="claim_comments"/>
                                    <field name="rejection_reason"/>
                                    <field name="create_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="insurance_claim_tree_view" model="ir.ui.view">
        <field name="name">Insurance Claim Tree View</field>
        <field name="model">insurance.claim</field>
        <field name="arch" type="xml">
            <tree string="Claims">
                <field name="nhis_number"/>
                <field name="claimed_date"/>
                <field name="partner_id"/>
                <field name="claim_manager_id"/>
                <field name="care_setting"/>
            </tree>
        </field>
    </record>
    <record id="action_insurance_claims" model="ir.actions.act_window">
        <field name="name">Insurace Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="insurance_claim_tree_view"></field>
        <field name="domain">[('state', 'in', ('draft', 'confirmed'))]</field>
    </record>
    <record id="action_submitted_claims" model="ir.actions.act_window">
        <field name="name">Submitted Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="insurance_claim_tree_view"></field>
        <field name="domain">[('state', 'not in', ('draft', 'confirmed', 'rejected'))]</field>
    </record>
    <record id="action_rejected_claims" model="ir.actions.act_window">
        <field name="name">Rejected Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="insurance_claim_tree_view"></field>
        <field name="domain">[('state', '=', 'rejected')]</field>
    </record>
    <record id="action_checked_claims" model="ir.actions.act_window">
        <field name="name">Checked Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="insurance_claim_tree_view"></field>
        <field name="domain">[('state', '=', 'checked')]</field>
    </record>
    <record id="action_approved_claims" model="ir.actions.act_window">
        <field name="name">Approved Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="insurance_claim_tree_view"></field>
        <field name="domain">[('state', '=', 'passed')]</field>
    </record>
    <menuitem id="menu_claims" name="Claims" sequence="10" parent="menu_insurance_claims" action="action_insurance_claims"/>
    <menuitem id="menu_submitted_claims" name="Submitted Claims" sequence="10" parent="menu_insurance_claims" action="action_submitted_claims"/>
    <menuitem id="menu_rejected_claims" name="Rejected Claims" sequence="10" parent="menu_insurance_claims" action="action_rejected_claims"/>
    <menuitem id="menu_checked_claims" name="Checked Claims" sequence="10" parent="menu_insurance_claims" action="action_checked_claims"/>
    <menuitem id="menu_approved_claims" name="Approved Claims" sequence="10" parent="menu_insurance_claims" action="action_approved_claims"/>
</odoo>